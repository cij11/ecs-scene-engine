{
  "name": "ecs-scene-engine",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "directories": {
    "doc": "docs"
  },
  "workspaces": [
    "tooling/slack-notify"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "lsof -ti:4000 | xargs kill -9 2>/dev/null; vite",
    "build": "vite build",
    "ci": "bash tooling/ci.sh",
    "lint": "eslint \"engine/**/*.ts\" \"view/**/*.ts\" \"game/**/*.ts\" \"browser/**/*.ts\"",
    "format": "prettier --write \"engine/**/*.ts\" \"view/**/*.ts\" \"game/**/*.ts\" \"browser/**/*.ts\"",
    "format:check": "prettier --check \"engine/**/*.ts\" \"view/**/*.ts\" \"game/**/*.ts\" \"browser/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "capture": "npx tsx tooling/capture/capture.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cij11/ecs-scene-engine.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/cij11/ecs-scene-engine/issues"
  },
  "homepage": "https://github.com/cij11/ecs-scene-engine#readme",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/html-vite": "^10.3.3",
    "@types/node": "^25.5.0",
    "@vitest/browser-playwright": "^4.1.1",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^10.1.0",
    "eslint-plugin-storybook": "^10.3.3",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "storybook": "^10.3.3",
    "tsx": "^4.21.0",
    "typescript": "5.9",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.2",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@dimforge/rapier3d-deterministic": "^0.19.3",
    "@types/three": "^0.183.1",
    "three": "^0.183.2"
  }
}
